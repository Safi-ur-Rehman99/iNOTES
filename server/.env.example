# ==============================
# Server Environment Variables
# Copy this file to .env and fill in your values
# ==============================

# MongoDB connection string
# For local: mongodb://localhost:27017/iNotes
# For production: mongodb+srv://<user>:<pass>@cluster.xxxx.mongodb.net/iNotes
MONGO_URI=

# JWT Secret — use a strong random string in production (e.g. 64 chars)
JWT_SECRET=

# Port (Vercel ignores this — it's for local dev only)
PORT=5000

# Client origin URL for CORS
# For local: http://localhost:3000
# For production: https://your-client-app.vercel.app
CLIENT_URL=
